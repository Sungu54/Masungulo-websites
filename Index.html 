<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0, user-scalable=yes">
    <title>SA Student Hub - Professional News Platform</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=Playfair+Display:wght@700;800;900&display=swap" rel="stylesheet">
    <style>
        :root {
            --primary: #0f0f23; --secondary: #1a1a2e; --accent: #e94560; --accent-hover: #c73e54;
            --accent-light: #ffe0e6; --success: #00b894; --warning: #fdcb6e; --info: #0984e3;
            --bg: #f8f9fa; --card-bg: #ffffff; --text-primary: #0f0f23; --text-secondary: #5a5a72;
            --text-muted: #8e8ea0; --border: #e8e8ed;
            --shadow-sm: 0 1px 3px rgba(15,15,35,0.06); --shadow-md: 0 4px 16px rgba(15,15,35,0.08);
            --shadow-lg: 0 12px 40px rgba(15,15,35,0.12); --shadow-xl: 0 20px 60px rgba(15,15,35,0.16);
            --radius-sm: 8px; --radius-md: 12px; --radius-lg: 16px; --radius-xl: 24px;
            --transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }
        * { margin: 0; padding: 0; box-sizing: border-box; -webkit-tap-highlight-color: transparent; }
        html { scroll-behavior: smooth; -webkit-font-smoothing: antialiased; }
        body { font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif; background: var(--bg); color: var(--text-primary); line-height: 1.6; overflow-x: hidden; }
        ::-webkit-scrollbar { width: 6px; } ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb { background: var(--border); border-radius: 3px; }
        ::-webkit-scrollbar-thumb:hover { background: var(--text-muted); }

        .header { background: var(--card-bg); position: sticky; top: 0; z-index: 1000; box-shadow: var(--shadow-sm); transition: var(--transition); }
        .header.scrolled { box-shadow: var(--shadow-md); }
        .header-top { display: flex; align-items: center; justify-content: space-between; padding: 12px 16px; max-width: 1400px; margin: 0 auto; }
        .logo { display: flex; align-items: center; gap: 10px; text-decoration: none; }
        .logo-icon { width: 42px; height: 42px; background: linear-gradient(135deg, var(--accent), #ff6b6b); border-radius: var(--radius-sm); display: flex; align-items: center; justify-content: center; color: white; font-weight: 900; font-size: 18px; box-shadow: 0 2px 12px rgba(233,69,96,0.35); }
        .logo-text { font-family: 'Playfair Display', serif; font-size: 24px; font-weight: 900; color: var(--primary); letter-spacing: -0.5px; }
        .logo-text span { color: var(--accent); }
        .header-actions { display: flex; align-items: center; gap: 10px; }

        .btn { padding: 10px 22px; border-radius: 24px; font-size: 14px; font-weight: 600; cursor: pointer; transition: var(--transition); border: none; outline: none; display: inline-flex; align-items: center; gap: 6px; text-decoration: none; }
        .btn-outline { background: transparent; color: var(--text-primary); border: 2px solid var(--border); }
        .btn-outline:hover { border-color: var(--accent); color: var(--accent); background: var(--accent-light); }
        .btn-primary { background: var(--accent); color: white; box-shadow: 0 2px 12px rgba(233,69,96,0.35); }
        .btn-primary:hover { background: var(--accent-hover); transform: translateY(-2px); box-shadow: 0 6px 20px rgba(233,69,96,0.45); }
        .btn-ghost { background: transparent; color: var(--text-secondary); }
        .btn-ghost:hover { background: var(--bg); color: var(--accent); }
        .btn-lg { padding: 14px 32px; font-size: 16px; }
        .btn-block { width: 100%; justify-content: center; }
        .btn-danger { background: #ff4757; color: white; } .btn-danger:hover { background: #ee3742; }
        .btn-success { background: var(--success); color: white; } .btn-success:hover { background: #00a383; }
        .btn-info { background: var(--info); color: white; } .btn-info:hover { background: #0770c2; }
        .icon-btn { width: 40px; height: 40px; border-radius: 50%; display: flex; align-items: center; justify-content: center; background: transparent; border: none; cursor: pointer; color: var(--text-secondary); transition: var(--transition); }
        .icon-btn:hover { background: var(--bg); color: var(--accent); }
        .icon-btn.active { color: var(--accent); background: var(--accent-light); }

        .category-nav { background: var(--card-bg); border-top: 1px solid var(--border); position: sticky; top: 66px; z-index: 999; overflow-x: auto; scrollbar-width: none; -ms-overflow-style: none; }
        .category-nav::-webkit-scrollbar { display: none; }
        .category-list { display: flex; gap: 4px; padding: 10px 16px; max-width: 1400px; margin: 0 auto; min-width: max-content; }
        .category-tab { padding: 10px 18px; border-radius: 20px; font-size: 13px; font-weight: 600; color: var(--text-secondary); background: transparent; border: none; cursor: pointer; white-space: nowrap; transition: var(--transition); position: relative; }
        .category-tab:hover { color: var(--accent); background: rgba(233,69,96,0.06); }
        .category-tab.active { color: var(--accent); background: rgba(233,69,96,0.1); }
        .category-tab.active::after { content: ''; position: absolute; bottom: -10px; left: 50%; transform: translateX(-50%); width: 20px; height: 3px; background: var(--accent); border-radius: 2px; }

        .ad-banner { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; padding: 14px 16px; text-align: center; font-size: 13px; font-weight: 500; position: relative; overflow: hidden; cursor: pointer; }
        .ad-banner::before { content: 'AD'; position: absolute; top: 6px; right: 10px; font-size: 10px; opacity: 0.6; background: rgba(255,255,255,0.2); padding: 2px 8px; border-radius: 4px; font-weight: 700; }

        .container { max-width: 1400px; margin: 0 auto; padding: 20px 16px; }
        @media (min-width: 768px) { .container { padding: 24px; } }

        .skeleton { background: linear-gradient(90deg, var(--border) 25%, #f5f5f7 50%, var(--border) 75%); background-size: 200% 100%; animation: shimmer 1.5s infinite; border-radius: var(--radius-sm); }
        @keyframes shimmer { 0% { background-position: 200% 0; } 100% { background-position: -200% 0; } }
        .loading-spinner { width: 40px; height: 40px; border: 3px solid var(--border); border-top-color: var(--accent); border-radius: 50%; animation: spin 0.8s linear infinite; margin: 40px auto; }
        @keyframes spin { to { transform: rotate(360deg); } }
        .loading-text { text-align: center; color: var(--text-muted); font-size: 14px; margin-top: 12px; }

        .featured-section { margin-bottom: 32px; }
        .featured-card { background: var(--card-bg); border-radius: var(--radius-lg); overflow: hidden; box-shadow: var(--shadow-md); transition: var(--transition); cursor: pointer; position: relative; }
        .featured-card:hover { transform: translateY(-4px); box-shadow: var(--shadow-lg); }
        .featured-image { width: 100%; height: 300px; position: relative; overflow: hidden; }
        .featured-image img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.6s ease; }
        .featured-card:hover .featured-image img { transform: scale(1.03); }
        .featured-overlay { position: absolute; bottom: 0; left: 0; right: 0; background: linear-gradient(to top, rgba(15,15,35,0.9) 0%, rgba(15,15,35,0.4) 60%, transparent 100%); padding: 60px 24px 24px; color: white; }
        .featured-meta { display: flex; align-items: center; gap: 12px; margin-bottom: 14px; flex-wrap: wrap; }
        .category-badge { padding: 5px 14px; border-radius: 20px; font-size: 11px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.8px; }
        .badge-education { background: var(--success); color: white; }
        .badge-opportunities { background: var(--warning); color: var(--primary); }
        .badge-politics { background: var(--accent); color: white; }
        .badge-lifestyle { background: #74b9ff; color: white; }
        .badge-jobs { background: var(--info); color: white; }
        .badge-internships { background: #a29bfe; color: white; }
        .timestamp { font-size: 13px; opacity: 0.9; display: flex; align-items: center; gap: 6px; }
        .featured-title { font-family: 'Playfair Display', serif; font-size: 26px; font-weight: 900; line-height: 1.25; margin-bottom: 10px; }
        .featured-excerpt { font-size: 15px; opacity: 0.85; line-height: 1.6; max-width: 700px; }
        @media (min-width: 768px) { .featured-image { height: 420px; } .featured-title { font-size: 36px; } }

        .section-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 24px; }
        .section-title { font-size: 22px; font-weight: 800; color: var(--primary); display: flex; align-items: center; gap: 10px; }
        .trending-indicator { display: inline-flex; align-items: center; gap: 6px; color: var(--accent); font-size: 13px; font-weight: 700; animation: pulse 2s infinite; }
        @keyframes pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.5; } }
        .view-all { font-size: 14px; font-weight: 600; color: var(--accent); text-decoration: none; display: flex; align-items: center; gap: 4px; }
        .view-all:hover { text-decoration: underline; }

        .articles-grid { display: grid; grid-template-columns: 1fr; gap: 24px; margin-bottom: 40px; }
        @media (min-width: 640px) { .articles-grid { grid-template-columns: repeat(2, 1fr); } }
        @media (min-width: 1024px) { .articles-grid { grid-template-columns: repeat(3, 1fr); } }
        @media (min-width: 1280px) { .articles-grid { grid-template-columns: repeat(4, 1fr); } }

        .article-card { background: var(--card-bg); border-radius: var(--radius-md); overflow: hidden; box-shadow: var(--shadow-sm); transition: var(--transition); cursor: pointer; display: flex; flex-direction: column; height: 100%; }
        .article-card:hover { transform: translateY(-6px); box-shadow: var(--shadow-lg); }
        .article-image { width: 100%; height: 200px; position: relative; overflow: hidden; }
        .article-image img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.5s ease; }
        .article-card:hover .article-image img { transform: scale(1.05); }
        .article-image .category-badge { position: absolute; top: 12px; left: 12px; z-index: 2; }
        .article-content { padding: 18px; flex: 1; display: flex; flex-direction: column; }
        .article-meta { display: flex; align-items: center; gap: 10px; margin-bottom: 10px; }
        .article-source { font-size: 12px; font-weight: 700; color: var(--accent); text-transform: uppercase; letter-spacing: 0.5px; }
        .article-title { font-size: 17px; font-weight: 800; line-height: 1.35; margin-bottom: 10px; color: var(--text-primary); display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
        .article-excerpt { font-size: 14px; color: var(--text-secondary); line-height: 1.6; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; flex: 1; }
        .article-footer { display: flex; align-items: center; justify-content: space-between; margin-top: 14px; padding-top: 14px; border-top: 1px solid var(--border); }
        .read-time { font-size: 12px; color: var(--text-muted); display: flex; align-items: center; gap: 4px; font-weight: 500; }
        .save-btn { background: none; border: none; cursor: pointer; color: var(--text-muted); transition: var(--transition); padding: 6px; border-radius: 50%; }
        .save-btn:hover, .save-btn.saved { color: var(--accent); background: var(--accent-light); }
        .article-type-indicator { position: absolute; top: 12px; right: 12px; background: rgba(0,0,0,0.7); color: white; padding: 4px 10px; border-radius: 12px; font-size: 11px; font-weight: 700; }

        .affiliate-banner { background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%); border-radius: var(--radius-md); padding: 24px; margin-bottom: 32px; color: white; position: relative; overflow: hidden; cursor: pointer; }
        .affiliate-banner::before { content: ''; position: absolute; top: -50%; right: -20%; width: 300px; height: 300px; background: rgba(255,255,255,0.1); border-radius: 50%; }
        .affiliate-content { position: relative; z-index: 1; }
        .affiliate-label { font-size: 11px; font-weight: 800; text-transform: uppercase; letter-spacing: 1.5px; opacity: 0.9; margin-bottom: 10px; }
        .affiliate-title { font-size: 20px; font-weight: 800; margin-bottom: 10px; }
        .affiliate-link { display: inline-flex; align-items: center; gap: 6px; color: white; font-size: 14px; font-weight: 700; text-decoration: underline; text-underline-offset: 4px; }

        .search-overlay { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(15,15,35,0.85); backdrop-filter: blur(12px); z-index: 2000; display: none; align-items: flex-start; justify-content: center; padding-top: 80px; opacity: 0; transition: opacity 0.3s ease; }
        .search-overlay.active { display: flex; opacity: 1; }
        .search-container { width: 92%; max-width: 700px; background: var(--card-bg); border-radius: var(--radius-xl); padding: 28px; transform: translateY(-20px); transition: transform 0.3s ease; box-shadow: var(--shadow-xl); }
        .search-overlay.active .search-container { transform: translateY(0); }
        .search-input-wrapper { display: flex; align-items: center; gap: 14px; background: var(--bg); border-radius: var(--radius-lg); padding: 14px 20px; margin-bottom: 24px; border: 2px solid transparent; transition: var(--transition); }
        .search-input-wrapper:focus-within { border-color: var(--accent); background: white; }
        .search-input { flex: 1; border: none; background: none; font-size: 17px; font-family: inherit; outline: none; color: var(--text-primary); }
        .search-input::placeholder { color: var(--text-muted); }
        .search-suggestions-title { font-size: 12px; font-weight: 700; color: var(--text-muted); margin-bottom: 14px; text-transform: uppercase; letter-spacing: 1px; }
        .search-suggestions { display: flex; flex-wrap: wrap; gap: 10px; margin-bottom: 24px; }
        .suggestion-chip { padding: 8px 18px; background: var(--bg); border-radius: 20px; font-size: 14px; color: var(--text-secondary); cursor: pointer; transition: var(--transition); border: none; font-weight: 500; }
        .suggestion-chip:hover { background: var(--accent); color: white; transform: translateY(-2px); }
        .search-results { max-height: 400px; overflow-y: auto; }
        .search-result-item { padding: 14px; border-radius: var(--radius-md); cursor: pointer; transition: var(--transition); display: flex; gap: 14px; align-items: center; }
        .search-result-item:hover { background: var(--bg); }
        .search-result-img { width: 60px; height: 60px; border-radius: var(--radius-sm); object-fit: cover; flex-shrink: 0; }
        .search-result-title { font-size: 15px; font-weight: 700; color: var(--text-primary); margin-bottom: 4px; }
        .search-result-meta { font-size: 12px; color: var(--text-muted); }

        .bottom-nav { position: fixed; bottom: 0; left: 0; right: 0; background: var(--card-bg); border-top: 1px solid var(--border); padding: 8px 0 16px; z-index: 1000; box-shadow: 0 -4px 20px rgba(15,15,35,0.06); }
        .bottom-nav-list { display: flex; justify-content: space-around; align-items: center; max-width: 600px; margin: 0 auto; }
        .bottom-nav-item { display: flex; flex-direction: column; align-items: center; gap: 4px; padding: 4px 12px; color: var(--text-muted); text-decoration: none; font-size: 11px; font-weight: 600; transition: var(--transition); border: none; background: none; cursor: pointer; }
        .bottom-nav-item.active { color: var(--accent); }
        .bottom-nav-item svg { width: 24px; height: 24px; stroke-width: 2; }
        .bottom-nav-item.discover { position: relative; top: -20px; }
        .discover-btn { width: 58px; height: 58px; background: var(--accent); border-radius: 50%; display: flex; align-items: center; justify-content: center; color: white; box-shadow: 0 6px 20px rgba(233,69,96,0.4); border: 4px solid var(--bg); transition: var(--transition); }
        .discover-btn:hover { transform: scale(1.1) rotate(90deg); }

        .lang-switcher { position: relative; }
        .lang-dropdown { position: absolute; top: calc(100% + 10px); right: 0; background: var(--card-bg); border-radius: var(--radius-md); box-shadow: var(--shadow-xl); padding: 10px; min-width: 160px; display: none; opacity: 0; transform: translateY(-10px); transition: all 0.2s ease; z-index: 100; }
        .lang-dropdown.show { display: block; opacity: 1; transform: translateY(0); }
        .lang-option { padding: 10px 14px; border-radius: var(--radius-sm); font-size: 14px; cursor: pointer; transition: var(--transition); display: flex; align-items: center; gap: 10px; font-weight: 500; }
        .lang-option:hover { background: var(--bg); }
        .lang-option.active { color: var(--accent); font-weight: 700; background: var(--accent-light); }

        .scroll-top { position: fixed; bottom: 100px; right: 20px; width: 50px; height: 50px; background: var(--accent); color: white; border-radius: 50%; display: flex; align-items: center; justify-content: center; cursor: pointer; opacity: 0; transform: translateY(20px); transition: var(--transition); box-shadow: var(--shadow-md); border: none; z-index: 100; }
        .scroll-top.visible { opacity: 1; transform: translateY(0); }
        .scroll-top:hover { transform: translateY(-4px); box-shadow: var(--shadow-lg); }

        .modal-overlay { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(15,15,35,0.7); backdrop-filter: blur(8px); z-index: 3000; display: none; align-items: center; justify-content: center; padding: 20px; opacity: 0; transition: opacity 0.3s ease; }
        .modal-overlay.active { display: flex; opacity: 1; }
        .modal { background: var(--card-bg); border-radius: var(--radius-xl); width: 100%; max-width: 520px; max-height: 90vh; overflow-y: auto; transform: scale(0.95); transition: transform 0.3s ease; box-shadow: var(--shadow-xl); }
        .modal-overlay.active .modal { transform: scale(1); }
        .modal-header { padding: 24px 28px 0; display: flex; align-items: center; justify-content: space-between; }
        .modal-title { font-size: 22px; font-weight: 800; }
        .modal-close { width: 36px; height: 36px; border-radius: 50%; border: none; background: var(--bg); cursor: pointer; display: flex; align-items: center; justify-content: center; color: var(--text-secondary); transition: var(--transition); }
        .modal-close:hover { background: var(--accent-light); color: var(--accent); }
        .modal-body { padding: 20px 28px 28px; }
        .modal-footer { padding: 0 28px 24px; display: flex; gap: 12px; }

        .form-group { margin-bottom: 20px; }
        .form-label { display: block; font-size: 14px; font-weight: 600; color: var(--text-primary); margin-bottom: 8px; }
        .form-input, .form-textarea, .form-select { width: 100%; padding: 14px 18px; border: 2px solid var(--border); border-radius: var(--radius-md); font-size: 15px; font-family: inherit; transition: var(--transition); background: var(--bg); color: var(--text-primary); }
        .form-input:focus, .form-textarea:focus, .form-select:focus { outline: none; border-color: var(--accent); background: white; box-shadow: 0 0 0 4px rgba(233,69,96,0.1); }
        .form-textarea { min-height: 120px; resize: vertical; }
        .form-select { cursor: pointer; }
        .form-hint { font-size: 12px; color: var(--text-muted); margin-top: 6px; }
        .form-error { font-size: 13px; color: #ff4757; margin-top: 6px; display: none; }
        .form-error.show { display: block; }

        .auth-page { min-height: 100vh; display: flex; align-items: center; justify-content: center; padding: 20px; background: linear-gradient(135deg, var(--primary) 0%, var(--secondary) 100%); }
        .auth-card { background: var(--card-bg); border-radius: var(--radius-xl); padding: 40px; width: 100%; max-width: 480px; box-shadow: var(--shadow-xl); }
        .auth-logo { text-align: center; margin-bottom: 32px; }
        .auth-logo .logo { justify-content: center; }
        .auth-title { font-size: 28px; font-weight: 900; text-align: center; margin-bottom: 8px; }
        .auth-subtitle { text-align: center; color: var(--text-secondary); margin-bottom: 32px; font-size: 15px; }
        .auth-footer { text-align: center; margin-top: 24px; font-size: 14px; color: var(--text-secondary); }
        .auth-footer a { color: var(--accent); font-weight: 600; text-decoration: none; }
        .auth-footer a:hover { text-decoration: underline; }
        .social-login { display: flex; gap: 12px; margin-bottom: 24px; }
        .social-btn { flex: 1; padding: 12px; border: 2px solid var(--border); border-radius: var(--radius-md); background: white; cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 8px; font-weight: 600; font-size: 14px; transition: var(--transition); }
        .social-btn:hover { border-color: var(--accent); background: var(--accent-light); }
        .divider { display: flex; align-items: center; gap: 16px; margin: 24px 0; color: var(--text-muted); font-size: 13px; font-weight: 500; }
        .divider::before, .divider::after { content: ''; flex: 1; height: 1px; background: var(--border); }

        .admin-layout { display: flex; min-height: 100vh; }
        .admin-sidebar { width: 260px; background: var(--primary); color: white; position: fixed; height: 100vh; overflow-y: auto; z-index: 100; }
        .admin-sidebar-header { padding: 24px; border-bottom: 1px solid rgba(255,255,255,0.1); }
        .admin-sidebar-header .logo-text { color: white; font-size: 22px; }
        .admin-nav { padding: 16px 12px; }
        .admin-nav-item { display: flex; align-items: center; gap: 12px; padding: 12px 16px; border-radius: var(--radius-md); color: rgba(255,255,255,0.7); text-decoration: none; font-size: 14px; font-weight: 600; transition: var(--transition); cursor: pointer; border: none; background: none; width: 100%; }
        .admin-nav-item:hover, .admin-nav-item.active { background: rgba(255,255,255,0.1); color: white; }
        .admin-nav-item svg { width: 20px; height: 20px; }
        .admin-main { flex: 1; margin-left: 260px; background: var(--bg); min-height: 100vh; }
        .admin-header { background: var(--card-bg); padding: 16px 32px; display: flex; align-items: center; justify-content: space-between; border-bottom: 1px solid var(--border); position: sticky; top: 0; z-index: 50; }
        .admin-content { padding: 32px; max-width: 1200px; }
        .stats-grid { display: grid; grid-template-columns: repeat(1, 1fr); gap: 20px; margin-bottom: 32px; }
        @media (min-width: 640px) { .stats-grid { grid-template-columns: repeat(2, 1fr); } }
        @media (min-width: 1024px) { .stats-grid { grid-template-columns: repeat(4, 1fr); } }
        .stat-card { background: var(--card-bg); border-radius: var(--radius-md); padding: 24px; box-shadow: var(--shadow-sm); }
        .stat-label { font-size: 13px; font-weight: 600; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 8px; }
        .stat-value { font-size: 32px; font-weight: 900; color: var(--primary); margin-bottom: 8px; }
        .stat-change { font-size: 13px; font-weight: 600; display: flex; align-items: center; gap: 4px; }
        .stat-change.positive { color: var(--success); }
        .stat-change.negative { color: var(--accent); }
        .admin-table { width: 100%; background: var(--card-bg); border-radius: var(--radius-md); overflow: hidden; box-shadow: var(--shadow-sm); }
        .admin-table table { width: 100%; border-collapse: collapse; }
