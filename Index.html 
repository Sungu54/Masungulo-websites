                                                <button class="table-btn table-btn-delete" onclick="app.deleteArticle('${article.id}')">Delete</button>
                                            </div>
                                        </td>
                                    </tr>
                                `).join('')}
                            </tbody>
                        </table>
                    </div>
                `;
            } else if (section === 'create') {
                title.textContent = 'Create New Post';
                content.innerHTML = `
                    <form onsubmit="app.handleCreatePost(event)">
                        <div class="form-group">
                            <label class="form-label">Article Title *</label>
                            <input type="text" class="form-input" id="postTitle" placeholder="Enter a catchy headline" required>
                        </div>
                        <div class="form-group">
                            <label class="form-label">Category *</label>
                            <select class="form-select" id="postCategory" required>
                                <option value="">Select category</option>
                                <option value="top-stories">Top Stories</option>
                                <option value="student-news">Student News</option>
                                <option value="bursaries">Bursaries</option>
                                <option value="jobs">Jobs</option>
                                <option value="internships">Internships</option>
                                <option value="lifestyle">Lifestyle</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label class="form-label">Featured Image URL</label>
                            <input type="url" class="form-input" id="postImage" placeholder="https://example.com/image.jpg">
                            <div class="form-hint">Leave empty for auto-generated image</div>
                        </div>
                        <div class="form-group">
                            <label class="form-label">Short Excerpt *</label>
                            <input type="text" class="form-input" id="postExcerpt" placeholder="Brief summary (2-3 sentences)" required maxlength="200">
                        </div>
                        <div class="form-group">
                            <label class="form-label">Full Content *</label>
                            <textarea class="form-textarea" id="postContent" placeholder="Write your full article here... Use HTML for formatting." required></textarea>
                        </div>
                        <div class="form-group">
                            <label class="form-label">Author Name</label>
                            <input type="text" class="form-input" id="postAuthor" value="Ngomani Masungulo">
                        </div>
                        <div class="form-group">
                            <label class="form-label">Status</label>
                            <select class="form-select" id="postStatus">
                                <option value="published">Published</option>
                                <option value="draft">Draft</option>
                            </select>
                        </div>
                        <div style="display: flex; gap: 12px;">
                            <button type="submit" class="btn btn-primary btn-lg">Publish Article</button>
                            <button type="button" class="btn btn-outline" onclick="app.showAdminSection('articles')">Cancel</button>
                        </div>
                    </form>
                `;
            } else if (section === 'subscribers') {
                title.textContent = 'Subscribers';
                content.innerHTML = `
                    <div class="stats-grid" style="grid-template-columns: repeat(2, 1fr);">
                        <div class="stat-card">
                            <div class="stat-label">Free Users</div>
                            <div class="stat-value">3.2k</div>
                        </div>
                        <div class="stat-card">
                            <div class="stat-label">Paid Subscribers</div>
                            <div class="stat-value">847</div>
                        </div>
                    </div>
                    <div class="admin-table">
                        <table>
                            <thead><tr><th>User</th><th>Plan</th><th>Joined</th><th>Status</th></tr></thead>
                            <tbody>
                                <tr><td>student@uct.ac.za</td><td>Student Pro</td><td>2026-04-28</td><td><span class="status-badge status-published">Active</span></td></tr>
                                <tr><td>learner@wits.ac.za</td><td>Free</td><td>2026-04-27</td><td><span class="status-badge status-published">Active</span></td></tr>
                                <tr><td>grad@uj.ac.za</td><td>Student Premium</td><td>2026-04-25</td><td><span class="status-badge status-published">Active</span></td></tr>
                            </tbody>
                        </table>
                    </div>
                `;
            } else if (section === 'settings') {
                title.textContent = 'Settings';
                content.innerHTML = `
                    <div style="background: var(--card-bg); border-radius: var(--radius-md); padding: 24px; box-shadow: var(--shadow-sm); margin-bottom: 24px;">
                        <h3 style="font-size: 18px; font-weight: 800; margin-bottom: 16px;">API Configuration</h3>
                        <div class="form-group">
                            <label class="form-label">NewsAPI Key</label>
                            <input type="text" class="form-input" value="${this.config.NEWS_API_KEY}" readonly style="background: var(--bg);">
                            <div class="form-hint">Get your free key from newsapi.org</div>
                        </div>
                        <div class="form-group">
                            <label class="form-label">Supabase URL</label>
                            <input type="text" class="form-input" value="${this.config.SUPABASE_URL}" readonly style="background: var(--bg);">
                        </div>
                        <div class="form-group">
                            <label class="form-label">Paystack Public Key</label>
                            <input type="text" class="form-input" value="${this.config.PAYSTACK_PUBLIC_KEY}" readonly style="background: var(--bg);">
                        </div>
                    </div>
                    <div style="background: var(--card-bg); border-radius: var(--radius-md); padding: 24px; box-shadow: var(--shadow-sm);">
                        <h3 style="font-size: 18px; font-weight: 800; margin-bottom: 16px;">Admin Credentials</h3>
                        <div class="form-group">
                            <label class="form-label">Admin Email</label>
                            <input type="email" class="form-input" value="${this.config.ADMIN_EMAIL}" readonly style="background: var(--bg);">
                        </div>
                        <div class="form-hint" style="color: var(--warning);">⚠️ Change these credentials before going live!</div>
                    </div>
                `;
            }
        },

        handleCreatePost(e) {
            e.preventDefault();
            const article = {
                id: 'manual-' + Date.now(),
                title: document.getElementById('postTitle').value,
                category: document.getElementById('postCategory').value,
                image: document.getElementById('postImage').value || 'https://images.unsplash.com/photo-1523050854058-8df90110c9f1?w=600&h=400&fit=crop',
                excerpt: document.getElementById('postExcerpt').value,
                content: document.getElementById('postContent').value,
                author: document.getElementById('postAuthor').value,
                status: document.getElementById('postStatus').value,
                source: 'SA Student Hub',
                publishedAt: new Date().toISOString(),
                isManual: true,
                readTime: Math.ceil(document.getElementById('postContent').value.length / 1000) + ' min'
            };
            this.state.articles.unshift(article);
            localStorage.setItem('manualArticles', JSON.stringify(this.state.articles));
            this.showToast('Article published successfully!', 'success');
            this.showAdminSection('articles');
            this.renderManualArticles();
        },

        editArticle(id) {
            const article = this.state.articles.find(a => a.id === id);
            if (!article) return;
            this.showAdminSection('create');
            document.getElementById('adminPageTitle').textContent = 'Edit Article';
            setTimeout(() => {
                document.getElementById('postTitle').value = article.title;
                document.getElementById('postCategory').value = article.category;
                document.getElementById('postImage').value = article.image;
                document.getElementById('postExcerpt').value = article.excerpt;
                document.getElementById('postContent').value = article.content;
                document.getElementById('postAuthor').value = article.author;
                document.getElementById('postStatus').value = article.status;
                const form = document.querySelector('form[onsubmit="app.handleCreatePost(event)"]');
                form.onsubmit = (e) => {
                    e.preventDefault();
                    article.title = document.getElementById('postTitle').value;
                    article.category = document.getElementById('postCategory').value;
                    article.image = document.getElementById('postImage').value;
                    article.excerpt = document.getElementById('postExcerpt').value;
                    article.content = document.getElementById('postContent').value;
                    article.author = document.getElementById('postAuthor').value;
                    article.status = document.getElementById('postStatus').value;
                    localStorage.setItem('manualArticles', JSON.stringify(this.state.articles));
                    this.showToast('Article updated successfully!', 'success');
                    this.showAdminSection('articles');
                    this.renderManualArticles();
                };
            }, 100);
        },

        deleteArticle(id) {
            if (!confirm('Are you sure you want to delete this article? This cannot be undone.')) return;
            this.state.articles = this.state.articles.filter(a => a.id !== id);
            localStorage.setItem('manualArticles', JSON.stringify(this.state.articles));
            this.showToast('Article deleted', 'info');
            this.showAdminSection('articles');
            this.renderManualArticles();
        },

        // ==================== SUBSCRIPTION & PAYMENT ====================
        showSubscription() {
            this.hideAllPages();
            document.getElementById('subscriptionPage').classList.remove('hidden');
            window.scrollTo(0, 0);
            document.title = 'Subscribe | SA Student Hub';
        },

        showPayment(plan) {
            this.state.selectedPlan = plan;
            const prices = { pro: 'R49/month', premium: 'R99/month' };
            const names = { pro: 'Student Pro', premium: 'Student Premium' };
            document.getElementById('paymentPlanName').textContent = names[plan];
            document.getElementById('paymentPlanPrice').textContent = prices[plan];
            document.getElementById('paymentModal').classList.add('active');
        },

        closePayment() {
            document.getElementById('paymentModal').classList.remove('active');
            this.state.selectedPlan = null;
            this.state.selectedPaymentMethod = null;
        },

        selectPayment(el, method) {
            document.querySelectorAll('.payment-method').forEach(m => m.classList.remove('selected'));
            el.classList.add('selected');
            this.state.selectedPaymentMethod = method;
        },

        processPayment() {
            const name = document.getElementById('paymentName').value;
            const email = document.getElementById('paymentEmail').value;
            if (!name || !email) {
                this.showToast('Please fill in all fields', 'error');
                return;
            }
            if (!this.state.selectedPaymentMethod) {
                this.showToast('Please select a payment method', 'error');
                return;
            }
            if (this.state.selectedPaymentMethod === 'paystack' && this.config.PAYSTACK_PUBLIC_KEY !== 'pk_test_YOUR_PAYSTACK_KEY_HERE') {
                this.showToast('Paystack integration ready. Add your public key to activate.', 'info');
                return;
            }
            if (this.state.selectedPaymentMethod === 'stripe' && this.config.STRIPE_PUBLIC_KEY !== 'pk_test_YOUR_STRIPE_KEY_HERE') {
                this.showToast('Stripe integration ready. Add your public key to activate.', 'info');
                return;
            }
            this.closePayment();
            this.showToast(`Payment successful! Welcome to ${this.state.selectedPlan === 'pro' ? 'Student Pro' : 'Student Premium'}!`, 'success');
            this.goHome();
        },

        // ==================== NAVIGATION ====================
        goHome() {
            this.hideAllPages();
            document.getElementById('homePage').classList.remove('hidden');
            this.state.currentPage = 'home';
            window.scrollTo(0, 0);
            document.title = 'SA Student Hub - Trusted News for Students';
            this.renderAPINews();
            this.renderManualArticles();
        },

        hideAllPages() {
            document.getElementById('homePage').classList.add('hidden');
            document.getElementById('articlePage').classList.add('hidden');
            document.getElementById('authPage').classList.add('hidden');
            document.getElementById('subscriptionPage').classList.add('hidden');
            document.getElementById('adminPage').classList.add('hidden');
        },

        showDiscover() {
            this.showToast('Discover: Personalized content coming soon!', 'info');
        },

        showSaved() {
            if (this.state.savedArticles.length === 0) {
                this.showToast('No saved articles yet. Click the bookmark icon to save!', 'info');
                return;
            }
            this.showToast(`You have ${this.state.savedArticles.length} saved articles`, 'info');
        },

        showProfile() {
            if (this.state.user) {
                this.showToast(`Logged in as ${this.state.user.name || this.state.user.email}`, 'info');
            } else {
                this.showAuth('signin');
            }
        },

        showContact() {
            this.showToast('Contact: admin@sastudenthub.co.za', 'info');
        },

        // ==================== ARTICLE ACTIONS ====================
        toggleSave(id) {
            const index = this.state.savedArticles.indexOf(id);
            if (index > -1) {
                this.state.savedArticles.splice(index, 1);
                this.showToast('Article removed from saved', 'info');
            } else {
                this.state.savedArticles.push(id);
                this.showToast('Article saved!', 'success');
            }
            localStorage.setItem('savedArticles', JSON.stringify(this.state.savedArticles));
            this.renderManualArticles();
            this.renderAPINews();
        },

        saveCurrentArticle() {
            if (this.state.currentArticle) {
                this.toggleSave(this.state.currentArticle.id);
            }
        },

        shareArticle() {
            if (navigator.share && this.state.currentArticle) {
                navigator.share({
                    title: this.state.currentArticle.title,
                    text: this.state.currentArticle.excerpt,
                    url: window.location.href
                });
            } else {
                this.copyLink();
            }
        },

        shareTo(platform) {
            const url = encodeURIComponent(window.location.href);
            const text = encodeURIComponent(this.state.currentArticle ? this.state.currentArticle.title : 'SA Student Hub');
            let shareUrl = '';
            if (platform === 'twitter') shareUrl = `https://twitter.com/intent/tweet?url=${url}&text=${text}`;
            if (platform === 'facebook') shareUrl = `https://www.facebook.com/sharer/sharer.php?u=${url}`;
            if (platform === 'whatsapp') shareUrl = `https://wa.me/?text=${text}%20${url}`;
            window.open(shareUrl, '_blank', 'width=600,height=400');
        },

        copyLink() {
            navigator.clipboard.writeText(window.location.href).then(() => {
                this.showToast('Link copied to clipboard!', 'success');
            });
        },

        // ==================== LANGUAGE ====================
        switchLang(lang) {
            this.state.language = lang;
            localStorage.setItem('lang', lang);
            document.querySelectorAll('.lang-option').forEach(opt => {
                opt.classList.toggle('active', opt.dataset.lang === lang);
            });
            if (lang === 'zu') {
                document.querySelectorAll('.logo-text').forEach(el => el.innerHTML = 'I-Student <span>Hub</span>');
                const signinBtn = document.querySelector('.btn-outline');
                if (signinBtn && signinBtn.textContent.includes('Sign')) signinBtn.textContent = 'Ngena';
                const subBtn = document.querySelector('.btn-primary');
                if (subBtn && subBtn.textContent.includes('Subscribe')) subBtn.textContent = 'Bhalisa';
                this.showToast('Ulimi lushintshelwe kwisiZulu', 'success');
            } else {
                document.querySelectorAll('.logo-text').forEach(el => el.innerHTML = 'Student <span>Hub</span>');
                const signinBtn = document.querySelector('.btn-outline');
                if (signinBtn && signinBtn.textContent.includes('Ngena')) signinBtn.textContent = 'Sign in';
                const subBtn = document.querySelector('.btn-primary');
                if (subBtn && subBtn.textContent.includes('Bhalisa')) subBtn.textContent = 'Subscribe';
                this.showToast('Language switched to English', 'success');
            }
        },

        // ==================== UTILITIES ====================
        formatTime(date) {
            if (!date) return 'Just now';
            const now = new Date();
            const diff = (now - date) / 1000;
            if (diff < 60) return 'Just now';
            if (diff < 3600) return Math.floor(diff / 60) + 'm ago';
            if (diff < 86400) return Math.floor(diff / 3600) + 'h ago';
            if (diff < 604800) return Math.floor(diff / 86400) + 'd ago';
            return date.toLocaleDateString('en-ZA', { day: 'numeric', month: 'short' });
        },

        showToast(message, type = 'info') {
            const container = document.getElementById('toastContainer');
            const toast = document.createElement('div');
            toast.className = `toast toast-${type}`;
            const icons = {
                success: '<svg class="toast-icon" viewBox="0 0 24 24" fill="none" stroke="#00b894" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>',
                error: '<svg class="toast-icon" viewBox="0 0 24 24" fill="none" stroke="#ff4757" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>',
                info: '<svg class="toast-icon" viewBox="0 0 24 24" fill="none" stroke="#0984e3" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>'
            };
            toast.innerHTML = `
                ${icons[type]}
                <div class="toast-content">
                    <div class="toast-title">${type.charAt(0).toUpperCase() + type.slice(1)}</div>
                    <div class="toast-message">${message}</div>
                </div>
                <button class="toast-close" onclick="this.parentElement.remove()">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
                </button>
            `;
            container.appendChild(toast);
            requestAnimationFrame(() => toast.classList.add('show'));
            setTimeout(() => {
                toast.classList.remove('show');
                setTimeout(() => toast.remove(), 400);
            }, 4000);
        }
    };

    document.addEventListener('DOMContentLoaded', () => app.init());
    </script>
</body>
</html>
