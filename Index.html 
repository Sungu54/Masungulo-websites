    </button>
    <script>
    // ==================== SA STUDENT HUB - PRODUCTION APP ====================
    const app = {
        // CONFIGURATION - REPLACE WITH YOUR REAL API KEYS
        config: {
            NEWS_API_KEY: 'YOUR_NEWS_API_KEY_HERE',
            NEWS_API_URL: 'https://newsapi.org/v2/everything',
            SUPABASE_URL: 'https://your-project.supabase.co',
            SUPABASE_KEY: 'YOUR_SUPABASE_ANON_KEY_HERE',
            PAYSTACK_PUBLIC_KEY: 'pk_test_YOUR_PAYSTACK_KEY_HERE',
            STRIPE_PUBLIC_KEY: 'pk_test_YOUR_STRIPE_KEY_HERE',
            ADMIN_EMAIL: 'admin@sastudenthub.co.za',
            ADMIN_PASSWORD: 'Admin@2026!'
        },

        state: {
            currentPage: 'home',
            currentCategory: 'all',
            articles: [],
            apiArticles: [],
            savedArticles: JSON.parse(localStorage.getItem('savedArticles') || '[]'),
            user: JSON.parse(localStorage.getItem('user') || 'null'),
            isAdmin: localStorage.getItem('isAdmin') === 'true',
            language: localStorage.getItem('lang') || 'en',
            currentArticle: null,
            selectedPlan: null,
            selectedPaymentMethod: null
        },

        init() {
            this.setupEventListeners();
            this.loadManualArticles();
            this.fetchAPINews();
            this.updateAuthUI();
            this.setupScrollEffects();
        },

        setupEventListeners() {
            window.addEventListener('scroll', () => {
                const header = document.getElementById('header');
                if (window.scrollY > 50) header.classList.add('scrolled');
                else header.classList.remove('scrolled');
                const scrollTop = document.getElementById('scrollTop');
                if (window.scrollY > 500) scrollTop.classList.add('visible');
                else scrollTop.classList.remove('visible');
            });

            document.getElementById('langBtn').addEventListener('click', (e) => {
                e.stopPropagation();
                document.getElementById('langDropdown').classList.toggle('show');
            });
            document.addEventListener('click', () => {
                document.getElementById('langDropdown').classList.remove('show');
            });

            document.getElementById('searchBtn').addEventListener('click', () => this.openSearch());
            document.getElementById('bottomSearchBtn').addEventListener('click', () => this.openSearch());
            document.getElementById('closeSearch').addEventListener('click', () => this.closeSearch());
            document.getElementById('searchOverlay').addEventListener('click', (e) => {
                if (e.target === document.getElementById('searchOverlay')) this.closeSearch();
            });
            document.getElementById('searchInput').addEventListener('input', (e) => this.handleSearch(e.target.value));
            document.getElementById('searchInput').addEventListener('keydown', (e) => {
                if (e.key === 'Enter') this.search(document.getElementById('searchInput').value);
            });
        },

        setupScrollEffects() {
            const observer = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        entry.target.style.opacity = '1';
                        entry.target.style.transform = 'translateY(0)';
                    }
                });
            }, { threshold: 0.1 });
            document.querySelectorAll('.article-card').forEach(card => observer.observe(card));
        },

        // ==================== NEWS API ====================
        async fetchAPINews() {
            const container = document.getElementById('apiNewsContainer');
            if (this.config.NEWS_API_KEY === 'YOUR_NEWS_API_KEY_HERE') {
                this.renderDemoNews();
                return;
            }
            try {
                const queries = [
                    'South Africa students bursary NSFAS',
                    'South Africa university internship job graduate',
                    'South Africa education student accommodation'
                ];
                const query = queries[Math.floor(Math.random() * queries.length)];
                const url = `${this.config.NEWS_API_URL}?q=${encodeURIComponent(query)}&language=en&sortBy=publishedAt&pageSize=6&apiKey=${this.config.NEWS_API_KEY}`;
                const response = await fetch(url);
                const data = await response.json();
                if (data.status === 'ok' && data.articles) {
                    this.state.apiArticles = data.articles.map((article, index) => ({
                        id: `api-${index}`,
                        title: article.title,
                        excerpt: article.description || 'Click to read more...',
                        content: article.content || article.description || 'Full content not available.',
                        image: article.urlToImage || `https://images.unsplash.com/photo-${['1523050854058-8df90110c9f1','1524178232363-1fb2b075b655','1556761175-5973dc0f32e7','1517245386807-bb43f82c33c4','1523240795612-9a054b0db644','1434030216411-0b793f4b4173'][index]}?w=800&h=600&fit=crop`,
                        category: this.categorizeArticle(article.title + ' ' + (article.description || '')),
                        source: article.source.name,
                        author: article.author || article.source.name,
                        publishedAt: new Date(article.publishedAt),
                        url: article.url,
                        isAPI: true,
                        readTime: Math.ceil((article.content || article.description || '').length / 1000) + ' min'
                    }));
                    this.renderAPINews();
                } else {
                    throw new Error('API returned no articles');
                }
            } catch (error) {
                console.error('News API Error:', error);
                this.renderDemoNews();
                this.showToast('Using demo data. Add your NewsAPI key for live news.', 'info');
            }
        },

        categorizeArticle(text) {
            text = text.toLowerCase();
            if (text.includes('bursary') || text.includes('scholarship') || text.includes('fund') || text.includes('nsfas')) return 'bursaries';
            if (text.includes('job') || text.includes('career') || text.includes('employment') || text.includes('hire')) return 'jobs';
            if (text.includes('intern') || text.includes('trainee') || text.includes('graduate program')) return 'internships';
            if (text.includes('accommodation') || text.includes('residence') || text.includes('housing')) return 'student-news';
            if (text.includes('exam') || text.includes('study') || text.includes('mental health') || text.includes('lifestyle')) return 'lifestyle';
            return 'top-stories';
        },

        refreshNews() {
            const container = document.getElementById('apiNewsContainer');
            container.innerHTML = '<div class="loading-spinner"></div><p class="loading-text">Refreshing news feed...</p>';
            this.fetchAPINews();
            this.showToast('News feed refreshed!', 'success');
        },

        renderAPINews() {
            const container = document.getElementById('apiNewsContainer');
            const articles = this.state.currentCategory === 'all'
                ? this.state.apiArticles
                : this.state.apiArticles.filter(a => a.category === this.state.currentCategory);
            if (articles.length === 0) {
                container.innerHTML = '<p class="loading-text">No articles found in this category.</p>';
                return;
            }
            const featured = articles[0];
            const rest = articles.slice(1);
            let html = `
                <article class="featured-card animate-in" onclick="app.openArticle('${featured.id}')">
                    <div class="featured-image">
                        <img src="${featured.image}" alt="${featured.title}" onerror="this.src='https://images.unsplash.com/photo-1523050854058-8df90110c9f1?w=800&h=600&fit=crop'">
                        <div class="featured-overlay">
                            <div class="featured-meta">
                                <span class="category-badge badge-${featured.category === 'bursaries' ? 'opportunities' : featured.category === 'jobs' ? 'politics' : featured.category === 'internships' ? 'lifestyle' : 'education'}">${featured.category.replace('-', ' ').toUpperCase()}</span>
                                <span class="timestamp">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
                                    ${this.formatTime(featured.publishedAt)}
                                </span>
                            </div>
                            <h1 class="featured-title">${featured.title}</h1>
                            <p class="featured-excerpt">${featured.excerpt}</p>
                        </div>
                    </div>
                </article>
            `;
            if (rest.length > 0) {
                html += '<div class="articles-grid" style="margin-top: 24px;">';
                rest.forEach((article, i) => { html += this.renderArticleCard(article, i); });
                html += '</div>';
            }
            container.innerHTML = html;
            this.setupScrollEffects();
        },

        renderDemoNews() {
            const demoArticles = [
                { id: 'demo-1', title: "G20 without SA makes 'no sense', AU chief says as he promises to lobby for student representation", excerpt: "The African Union Commission chairperson emphasises the critical role of South African students in shaping continental education policy ahead of the G20 summit.", content: "<p>The African Union Commission chairperson has emphasised the critical role of South African students in shaping continental education policy ahead of the G20 summit.</p><p>Speaking at a press conference in Addis Ababa, the chairperson stated that any discussion about Africa's future without including South African student voices would be incomplete.</p><p>\"South Africa has one of the most vibrant and politically active student populations on the continent. Their input is essential,\" he said.</p>", image: "https://images.unsplash.com/photo-1523050854058-8df90110c9f1?w=800&h=600&fit=crop", category: "top-stories", source: "SA Student Hub", author: "Ngomani Masungulo", publishedAt: new Date(Date.now() - 42 * 60000), isAPI: false, readTime: "5 min" },
                { id: 'demo-2', title: "NSFAS confirms increased funding allowance for 2026 academic year", excerpt: "The National Student Financial Aid Scheme announces a 15% increase in accommodation and meal allowances for qualifying students.", content: "<p>The National Student Financial Aid Scheme (NSFAS) has confirmed a significant increase in funding allowances for the 2026 academic year.</p><p>Students who qualify for NSFAS funding will now receive a 15% increase in their accommodation and meal allowances, effective from January 2026.</p>", image: "https://images.unsplash.com/photo-1524178232363-1fb2b075b655?w=600&h=400&fit=crop", category: "bursaries", source: "NSFAS Official", author: "Finance Desk", publishedAt: new Date(Date.now() - 2 * 3600000), isAPI: false, readTime: "4 min" },
                { id: 'demo-3', title: "Major tech companies launch graduate recruitment drive across SA universities", excerpt: "Google, Microsoft, and local startups announce combined 2,000 entry-level positions for 2026 graduates in software engineering and data science.", content: "<p>Some of the world's biggest tech companies have announced a massive recruitment drive targeting South African graduates.</p><p>Google, Microsoft, and several local startups have committed to creating over 2,000 entry-level positions specifically for 2026 graduates.</p>", image: "https://images.unsplash.com/photo-1556761175-5973dc0f32e7?w=600&h=400&fit=crop", category: "jobs", source: "Tech SA", author: "Career Desk", publishedAt: new Date(Date.now() - 4 * 3600000), isAPI: false, readTime: "6 min" },
                { id: 'demo-4', title: "SAB launches R50m internship programme for hospitality and agriculture students", excerpt: "South African Breweries partners with TVET colleges to provide paid internships and practical training for 500 students nationwide.", content: "<p>South African Breweries (SAB) has announced a R50 million investment in a new internship programme targeting hospitality and agriculture students.</p><p>The programme will partner with TVET colleges across the country to provide paid internships for 500 students.</p>", image: "https://images.unsplash.com/photo-1517245386807-bb43f82c33c4?w=600&h=400&fit=crop", category: "internships", source: "SAB News", author: "Business Desk", publishedAt: new Date(Date.now() - 5 * 3600000), isAPI: false, readTime: "5 min" },
                { id: 'demo-5', title: "Wits University unveils new affordable student housing complex in Braamfontein", excerpt: "The R120 million development will provide 800 beds at subsidised rates, addressing the critical accommodation shortage for first-year students.", content: "<p>Wits University has unveiled a new student housing complex in Braamfontein designed to address the critical shortage of affordable accommodation.</p><p>The R120 million development will provide 800 beds at subsidised rates, primarily targeting first-year students.</p>", image: "https://images.unsplash.com/photo-1523240795612-9a054b0db644?w=600&h=400&fit=crop", category: "student-news", source: "Wits News", author: "Campus Desk", publishedAt: new Date(Date.now() - 8 * 3600000), isAPI: false, readTime: "3 min" },
                { id: 'demo-6', title: "10 proven study techniques to ace your June exams without burning out", excerpt: "Educational psychologists share evidence-based strategies for effective revision, stress management, and maintaining mental health during exam season.", content: "<p>As the June exam period approaches, educational psychologists have shared their top evidence-based strategies for effective studying.</p><p>From the Pomodoro Technique to active recall, these methods have been proven to improve retention while reducing burnout.</p>", image: "https://images.unsplash.com/photo-1434030216411-0b793f4b4173?w=600&h=400&fit=crop", category: "lifestyle", source: "Student Wellness", author: "Health Desk", publishedAt: new Date(Date.now() - 12 * 3600000), isAPI: false, readTime: "7 min" }
            ];
            this.state.apiArticles = demoArticles;
            this.renderAPINews();
        },

        // ==================== MANUAL ARTICLES ====================
        loadManualArticles() {
            let manualArticles = JSON.parse(localStorage.getItem('manualArticles') || 'null');
            if (!manualArticles) {
                manualArticles = [
                    { id: 'manual-1', title: "Fully-funded scholarships to study abroad: Top 5 programmes for SA students in 2026", excerpt: "From Chevening to Fulbright, we break down the most prestigious international scholarship opportunities and application deadlines.", content: "<p>Studying abroad can be a life-changing experience, but the cost often prevents many South African students from pursuing this dream.</p><p>Fortunately, there are several fully-funded scholarship programmes available specifically for South African students.</p><h2>1. Chevening Scholarships</h2><p>The UK government's global scholarship programme offers full financial support for a one-year master's degree at any UK university.</p><h2>2. Fulbright Program</h2><p>The US government's flagship international exchange programme provides funding for graduate study and research.</p>", image: "https://images.unsplash.com/photo-1531482615713-2afd69097998?w=600&h=400&fit=crop", category: "bursaries", source: "SA Student Hub", author: "Ngomani Masungulo", publishedAt: new Date(Date.now() - 24 * 3600000).toISOString(), status: "published", isManual: true, readTime: "8 min" },
                    { id: 'manual-2', title: "UJ launches new AI and Data Science faculty for 2026 intake", excerpt: "The University of Johannesburg announces a groundbreaking new faculty focused on artificial intelligence and data science education.", content: "<p>The University of Johannesburg has announced the launch of a new faculty dedicated to Artificial Intelligence and Data Science.</p><p>The faculty will offer undergraduate and postgraduate programmes starting from the 2026 academic year.</p>", image: "https://images.unsplash.com/photo-1516321318423-f06f85e504b3?w=600&h=400&fit=crop", category: "student-news", source: "SA Student Hub", author: "Ngomani Masungulo", publishedAt: new Date(Date.now() - 48 * 3600000).toISOString(), status: "published", isManual: true, readTime: "4 min" }
                ];
                localStorage.setItem('manualArticles', JSON.stringify(manualArticles));
            }
            this.state.articles = manualArticles;
            this.renderManualArticles();
        },

        renderManualArticles() {
            const container = document.getElementById('manualArticlesGrid');
            const articles = this.state.currentCategory === 'all'
                ? this.state.articles
                : this.state.articles.filter(a => a.category === this.state.currentCategory);
            if (articles.length === 0) {
                container.innerHTML = '<p class="loading-text">No editor picks yet. Create your first post in the admin dashboard!</p>';
                return;
            }
            container.innerHTML = articles.map((article, i) => this.renderArticleCard(article, i)).join('');
